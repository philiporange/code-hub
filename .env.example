# Code Hub Configuration
# Copy this to .env and adjust values as needed

# =============================================================================
# PATHS
# =============================================================================

# Base directory to scan for projects (default: ~/Code)
CODE_BASE_PATH=~/Code

# Directory for database and vector store (default: ~/.code_hub)
DATA_DIR=~/.code_hub

# Directories to exclude when scanning (comma-separated)
EXCLUDE_DIRS=node_modules,venv,.venv,__pycache__,.git,dist,build,.tox,eggs,*.egg-info,.next,.nuxt,target,vendor,.cargo

# =============================================================================
# CLAUDE CLI
# =============================================================================

# Timeout for Claude CLI commands in seconds (5 minutes for complex projects)
CLAUDE_TIMEOUT=300

# Maximum retry attempts for failed Claude calls
CLAUDE_MAX_RETRIES=3

# Rate limit: maximum requests per minute
CLAUDE_RATE_LIMIT=10

# Model for generating README.md files (high quality)
# Use aliases (sonnet, haiku, opus) or full names (claude-sonnet-4-5-20250929)
CLAUDE_README_MODEL=sonnet

# Model for generating METADATA.json (fast, structured)
CLAUDE_METADATA_MODEL=haiku

# Model for generating USAGE.md files (high quality)
CLAUDE_USAGE_MODEL=sonnet

# =============================================================================
# VECTOR STORE
# =============================================================================

# Sentence transformer model for embeddings
# Options: all-MiniLM-L6-v2 (fast), all-mpnet-base-v2 (better quality)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# =============================================================================
# WEB SERVER
# =============================================================================

# Server host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
SERVER_HOST=0.0.0.0

# Server port
SERVER_PORT=8000

# =============================================================================
# PROCESSING
# =============================================================================

# Number of projects to process in a batch
BATCH_SIZE=10

# Maximum parallel workers for processing
MAX_WORKERS=4
